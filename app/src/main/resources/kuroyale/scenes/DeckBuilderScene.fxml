      <Button layoutX="220.0" layoutY="360.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="440.0">
