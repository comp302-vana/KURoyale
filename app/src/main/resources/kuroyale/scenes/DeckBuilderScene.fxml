<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kuroyale.mainpack.DeckBuilder">
   <stylesheets>
      <URL value="@../styles/styles.css" />
   </stylesheets>

   <children>
      <!-- ScrollPane for available cards - centered -->
      <ScrollPane fx:id="cardScrollPane" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="310.0" AnchorPane.bottomAnchor="0.0">
         <content>
            <FlowPane fx:id="cardContainer" hgap="12.0" prefWrapLength="1200.0" style="-fx-background: transparent; -fx-background-color: transparent;" vgap="12.0" alignment="CENTER">
               <padding>
                  <Insets bottom="140.0" left="20.0" right="20.0" top="10.0" />
               </padding></FlowPane>
         </content>
      </ScrollPane>
      
      <!-- Available Cards Title - centered and impressive -->
      <Label text="✦ Available Cards ✦" textFill="white" alignment="CENTER" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="268.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 4, 0, 0, 2);">
         <font>
            <Font name="Trebuchet MS Bold" size="22.0" />
         </font>
      </Label>
      
      <!-- Deck Number Selector - 1 to 8 - centered -->
      <HBox fx:id="deckNumberSelector" alignment="CENTER" layoutX="40.0" layoutY="35.0" spacing="8.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">
