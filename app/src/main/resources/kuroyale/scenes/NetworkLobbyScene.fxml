<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: BD7FFF;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kuroyale.mainpack.network.NetworkLobbyController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label text="Network Lobby" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            
            <Label fx:id="lblConnectionInfo" text="" style="-fx-font-size: 14px; -fx-text-fill: #FFD700;">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <Label fx:id="lblIPAddress" text="" style="-fx-font-size: 14px; -fx-text-fill: white; -fx-font-weight: bold;">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <HBox spacing="30.0" alignment="TOP_LEFT">
               <children>
                  <VBox spacing="15.0" prefWidth="380.0" style="-fx-background-color: rgba(156, 39, 176, 0.3); -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label text="Players" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <ListView fx:id="listPlayers" prefHeight="400.0" style="-fx-background-color: rgba(255, 255, 255, 0.9);" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="15.0" prefWidth="380.0" style="-fx-background-color: rgba(156, 39, 176, 0.3); -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label text="Your Deck" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="lblDeckInfo" text="Loading deck..." style="-fx-text-fill: white; -fx-font-size: 14px;" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="15.0" prefWidth="380.0" style="-fx-background-color: rgba(156, 39, 176, 0.3); -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label text="Game Controls" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <CheckBox fx:id="chkReady" mnemonicParsing="false" onAction="#chkReadyChanged" text="Ready" style="-fx-text-fill: white; -fx-font-size: 16px;">
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </CheckBox>
                        <Button fx:id="btnStartGame" mnemonicParsing="false" onAction="#btnStartGameClicked" prefHeight="50.0" prefWidth="340.0" style="-fx-font-family: 'Trebuchet MS Bold'; -fx-font-size: 18px; -fx-background-color: #4CAF50; -fx-text-fill: white;" text="Start Game" />
                        <Button fx:id="btnLeave" mnemonicParsing="false" onAction="#btnLeaveClicked" prefHeight="40.0" prefWidth="340.0" style="-fx-font-family: 'Trebuchet MS Bold'; -fx-font-size: 16px; -fx-background-color: #F44336; -fx-text-fill: white;" text="Leave Lobby" />
                        <Label fx:id="lblStatus" text="" style="-fx-text-fill: #FFD700; -fx-font-size: 14px;" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>

